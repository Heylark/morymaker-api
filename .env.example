# api/.env.example — 컨테이너·운영 환경에서 오버라이드 가능한 키 정착지.
# 실값은 0개, 전부 플레이스홀더다. 로컬 개발(bootRun)은 이 파일이 없어도 application.yml
# 기본값만으로 그대로 동작한다 — 아래 값들은 배포 시점에만 필요하다.

# ── [프로필] ─────────────────────────────────────────────────────────
#  ⚠️ 현재 prod 는 기동 불가 — SmsSenderProdGuard 가 SMS 스텁 어댑터를 차단한다.
#     (문자 0건 발송인데 콘솔엔 성공 배지가 뜨는 조용한 실패를 막는 의도된 게이트)
#     실 SMS 채널 어댑터(벤더 확정 후 별도 작업) 도입 전까지 prod 사용 불가.
#     ⚠️ prod 를 끄면 아래 [URL — prod 가드] 4키의 https 검증도 함께 꺼진다 —
#        기본값(http://localhost)을 그대로 배포해도 아무도 막지 않으니 값 주입을 직접 확인할 것.
SPRING_PROFILES_ACTIVE=ajp                # 벤더 확정 후 → prod,ajp

# ── [로컬 개발 전용] application.yml 기본값 경로 ────────────────────
#  아래 SPRING_DATASOURCE_* 블록을 설정하면 이 두 키는 "조용히 무시"된다(실측 확인).
# DB_NAME=morymaker
# DB_ROOT_PASSWORD=changeme

# ── [컨테이너·운영] datasource 전체를 이 블록이 인수한다 ─────────────
#  ⚠️ 위 블록과 상호배타. 셋 중 하나라도 켜면 URL/계정 해석 주체가 여기로 넘어온다.
SPRING_DATASOURCE_URL=jdbc:mariadb://<db-host>:3306/<db-name>   # ⚠️ 컨테이너 내부 포트는 3306 (13306은 호스트 published)
SPRING_DATASOURCE_USERNAME=<db-user>
SPRING_DATASOURCE_PASSWORD=<db-password>

# ── [URL — prod 가드] prod 기동 시 https:// 미충족이면 기동 거부 ─────
AUTH_ISSUER=https://<auth-host>
PUBLIC_EVENT_BASE_URL=https://<web-host>/app
PARKING_QR_BASE_URL=https://<web-host>/app
PUBLIC_PARK_SCAN_URL=https://<web-host>/app/p

# ── [CORS] ⚠️ prod 가드 대상 아님 (의도된 비대칭 — QR·SMS 는 밖으로 나가면 되돌릴 수
#     없지만 CORS 오설정은 설정을 고쳐 되돌릴 수 있고 브라우저가 즉시 막는다) ─────────
ALLOWED_ORIGINS=https://<web-host>

# ── [AJP] ajp 프로필 시 ──────────────────────────────────────────────
#  ⚠️ 미주입(빈 값)이면 Tomcat 커넥터 start 시점에 기동 거부 (Ghostcat 방어)
AJP_SECRET=<shared-secret>

# ── [rate limit] 미설정 시 기본값(20 / 60초) ────────────────────────
# PUBLIC_RATE_LIMIT=20
# PUBLIC_RATE_LIMIT_WINDOW_SECONDS=60

# ── [SMS — 예약(비활성)] ⚠️ 아직 활성 키가 아니다 ────────────────────
#  application.yml 의 morymaker.sms.* 는 전 항목이 주석이라 YAML 파서에 도달하지
#  않고(파싱 결과 null), 이 값을 읽는 코드도 0건이다 — 여기에 값을 넣어도 아무 일도
#  일어나지 않는다. 벤더 확정 후 실 어댑터 도입 시 활성화되며, 그때 키 이름·개수가
#  조정될 수 있다(application.yml 주석 명시).
# SMS_API_KEY=
# SMS_API_SECRET=
